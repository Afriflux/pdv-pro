# ─── Yayyam Platform — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in the values.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma) ─────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yayyam.com
CRON_SECRET=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ── Payments — CinetPay ──────────────────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=

# ── Payments — PayTech ────────────────────────────────────────────────────────
PAYTECH_API_KEY=
PAYTECH_API_SECRET=

# ── Payments — Wave ───────────────────────────────────────────────────────────
WAVE_API_KEY=
WAVE_SECRET=

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Tracking Pixels (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ── Testing (optional) ────────────────────────────────────────────────────────
# TEST_ADMIN_EMAIL=
# TEST_VENDEUR_EMAIL=
# TEST_PASSWORD=
