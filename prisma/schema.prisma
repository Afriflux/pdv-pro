generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model User {
  id                    String                @id
  role                  Role                  @default(acheteur)
  name                  String
  phone                 String?               @unique
  email                 String?
  address               String?
  location_lat          Float?
  location_lng          Float?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  avatar_url            String?
  addresses             DeliveryAddress[]
  adminLogs             AdminLog[]
  Ambassador            Ambassador?
  Complaint             Complaint[]
  masterclassProgresses MasterclassProgress[]
  notifications         Notification[]
  npsResponses          NpsResponse[]
  orders                Order[]
  reports               Report[]
  store                 Store?
  tipReads              TipRead[]

  // ── Outils & Paramètres supplémentaires affilié/vendeur ──
  professional_phone String?
  social_links       Json?
  meta_pixel_id      String?
  tiktok_pixel_id    String?
  google_tag_id      String?

  // ── KYC Global (Affiliés & Closers) ──
  kyc_status        String? @default("unverified")
  kyc_document_type String?
  kyc_documents     Json?
  id_card_url       String?

  // ── Paramètres de retrait Closer/Affilié ──
  withdrawal_method                 String?  @default("wave")
  withdrawal_number                 String?
  withdrawal_name                   String?
  closer_auto_withdraw              Boolean? @default(false)
  closer_auto_withdraw_threshold    Float?   @default(50000)
  affiliate_auto_withdraw           Boolean? @default(false)
  affiliate_auto_withdraw_threshold Float?   @default(50000)

  // ── Balance Closer ──
  closer_balance      Float? @default(0)
  closer_total_earned Float? @default(0)

  CloserWithdrawal CloserWithdrawal[]

  // ── Portefeuille Client ──
  client_wallet_balance Float?         @default(0)
  client_payment_method String?        @default("wave")
  client_payment_number String?
  coachingSlots         CoachingSlot[]
  bookings              Booking[]
  blockedDates          BlockedDate[]
  workflows             Workflow[]
  tasks                 Task[]
  BioLink               BioLink?

  // ── YAYYAM OS ERP Relations ──
  internal_role_id  String?             @db.Uuid
  InternalRole      InternalRole?       @relation(fields: [internal_role_id], references: [id], onUpdate: NoAction)
  securityAuditLogs AuditLog[]
  employeeContract  EmployeeContract?
  shareholding      ShareholderEquity[]

  @@schema("public")
}

model DeliveryAddress {
  id             String   @id @default(uuid())
  user_id        String
  label          String   @default("Domicile")
  name           String
  phone          String
  address        String
  city           String?
  latitude       Float?
  longitude      Float?
  delivery_notes String?
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@schema("public")
}

model Store {
  id                                                  String                 @id @default(uuid())
  user_id                                             String                 @unique
  name                                                String
  slug                                                String                 @unique
  logo_url                                            String?
  primary_color                                       String?
  created_at                                          DateTime               @default(now())
  updated_at                                          DateTime               @updatedAt
  affiliate_active                                    Boolean                @default(false)
  affiliate_margin                                    Float                  @default(0.10)
  closer_active                                       Boolean                @default(false)
  closer_margin                                       Float                  @default(0.10)
  id_card_url                                         String?
  kyc_status                                          String                 @default("unverified")
  onboarding_completed                                Boolean                @default(false)
  security_pin                                        String?
  category                                            String?
  whatsapp                                            String?
  description                                         String?
  notif_new_order                                     Boolean                @default(true)
  notif_weekly_report                                 Boolean                @default(false)
  notif_stock_alert                                   Boolean                @default(true)
  banner_url                                          String?
  kyc_document_type                                   String?
  kyc_documents                                       Json?
  social_links                                        Json?
  meta_pixel_id                                       String?
  meta_capi_token                                     String?
  tiktok_pixel_id                                     String?
  google_tag_id                                       String?
  seo_title                                           String?
  seo_description                                     String?
  telegram_chat_id                                    String?
  telegram_notifications                              Json?                  @default("{\"stock\": true, \"orders\": true, \"payments\": true, \"whatsapp\": true}")
  referred_by                                         String?
  referred_by_ambassador                              String?
  registration_month                                  String?
  is_active                                           Boolean?               @default(true)
  withdrawal_method                                   String?                @default("wave")
  withdrawal_number                                   String?
  withdrawal_name                                     String?
  contract_accepted                                   Boolean?               @default(false)
  contract_accepted_at                                DateTime?              @db.Timestamptz(6)
  vendor_type                                         VendorType             @default(digital)
  closing_enabled                                     Boolean                @default(false)
  closing_fee                                         Float                  @default(500)
  coaching_max_per_day                                Int?                   @default(0)
  coaching_min_notice                                 Int?                   @default(24)
  coaching_auto_accept                                Boolean?               @default(true)
  coaching_buffer_time                                Int?                   @default(0)
  coaching_max_future_days                            Int?                   @default(60)
  payout_provider                                     String?
  payout_wallet_number                                String?
  whatsapp_abandoned_cart                             Boolean                @default(false)
  announcement_active                                 Boolean                @default(false)
  announcement_text                                   String?
  announcement_bg_color                               String?
  free_shipping_threshold                             Int?                   @default(0)
  gamification_active                                 Boolean?               @default(false)
  gamification_config                                 Json?
  vendor_type_updated_at                              DateTime?
  social_proof_active                                 Boolean                @default(false)
  social_proof_config                                 Json?
  volume_discounts_active                             Boolean                @default(false)
  volume_discounts_config                             Json?
  smart_reviews_active                                Boolean                @default(false)
  Affiliate                                           Affiliate[]
  AffiliateReferral                                   AffiliateReferral?
  Ambassador_Ambassador_store_idToStore               Ambassador[]           @relation("Ambassador_store_idToStore")
  HelpdeskTicket                                      HelpdeskTicket[]
  AmbassadorReferral                                  AmbassadorReferral?
  blockedDates                                        BlockedDate[]
  bookings                                            Booking[]
  closingRequests                                     ClosingRequest[]
  coachingSlots                                       CoachingSlot[]
  CommunityComment                                    CommunityComment[]
  CommunityLike                                       CommunityLike[]
  CommunityPost                                       CommunityPost[]
  Complaint                                           Complaint[]
  deliverers                                          Deliverer[]
  deliveryZones                                       DeliveryZone[]
  orders                                              Order[]
  products                                            Product[]
  promos                                              PromoCode[]
  promotions                                          Promotion[]
  Review                                              Review[]
  pages                                               SalePage[]
  shortLinks                                          ShortLink[]
  Store                                               Store?                 @relation("StoreToStore", fields: [referred_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_Store                                         Store[]                @relation("StoreToStore")
  user                                                User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Ambassador_Store_referred_by_ambassadorToAmbassador Ambassador?            @relation("Store_referred_by_ambassadorToAmbassador", fields: [referred_by_ambassador], references: [id], onUpdate: NoAction, map: "store_referred_by_ambassador_fkey")
  score                                               StoreScore?
  subscriptions                                       Subscription[]
  tasks                                               Task[]
  TelegramCommunity                                   TelegramCommunity[]
  wallet                                              Wallet?
  WithdrawalRequest                                   WithdrawalRequest[]
  workflows                                           Workflow[]
  telegram_link_tokens                                telegram_link_tokens[]
  leads                                               Lead[]
  themeTemplates                                      ThemeTemplate[]
  installedApps                                       InstalledApp[]
  webhooks                                            Webhook[]
  assetPurchases                                      AssetPurchase[]
  paymentLinks                                        PaymentLink[]
  quotes                                              Quote[]
  dailyDigests                                        DailyDigest[]
  whatsapp_bot                                        WhatsappBot?
  sms_credits                                         SmsCredit?
  sms_campaigns                                       SmsCampaign[]
  loyalty_config                                      LoyaltyConfig?
  loyalty_transactions                                LoyaltyTransaction[]

  @@schema("public")
}

model Product {
  id                      String      @id @default(uuid())
  store_id                String
  type                    ProductType
  name                    String
  description             String?
  price                   Float
  images                  String[]
  category                String?
  active                  Boolean     @default(true)
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt
  cash_on_delivery        Boolean     @default(false)
  digital_file_url        String?
  digital_link            String?
  shipping_fee            Float?
  shipping_delay          String?
  session_duration        String?
  session_mode            String?
  booking_link            String?
  access_duration_days    Int?
  digital_files           Json?
  license_notes           String?
  license_type            String?
  max_downloads           Int?
  video_download_allowed  Boolean     @default(false)
  views                   Int?        @default(0)
  resale_allowed          Boolean?    @default(false)
  resale_commission       Decimal?    @default(0.00) @db.Decimal(5, 2)
  seo_title               String?
  seo_description         String?
  template                String?     @default("default")
  coaching_type           String?     @default("individual")
  max_participants        Int?        @default(1)
  coaching_durations      Int[]       @default([60])
  coaching_is_pack        Boolean?    @default(false)
  coaching_pack_count     Int?        @default(1)
  sales                   Int         @default(0)
  affiliate_active        Boolean?
  affiliate_margin        Float?
  closer_active           Boolean?
  closer_margin           Float?
  payment_type            String?     @default("one_time")
  recurring_interval      String?
  affiliate_media_kit_url String?

  // Bump & Upsells
  bump_active     Boolean? @default(false)
  bump_offer_text String?
  bump_product_id String?
  oto_active      Boolean? @default(false)
  oto_product_id  String?
  oto_discount    Float?

  bookings          Booking[]
  Complaint         Complaint[]
  digitalAccess     DigitalAccess[]
  orders            Order[]
  store             Store               @relation(fields: [store_id], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  Review            Review[]
  shortLinks        ShortLink[]
  TelegramCommunity TelegramCommunity[]
  leads             Lead[]

  @@index([store_id])
  @@index([store_id], map: "idx_product_store_id")
  @@schema("public")
}

model ProductVariant {
  id           String  @id @default(uuid())
  product_id   String
  dimension_1  String?
  value_1      String?
  dimension_2  String?
  value_2      String?
  stock        Int     @default(0)
  price_adjust Float   @default(0)
  orders       Order[]
  product      Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id], map: "idx_product_variant_product_id")
  @@schema("public")
}

model SalePage {
  id                      String          @id @default(uuid())
  store_id                String
  title                   String
  slug                    String
  template                String
  sections                Json
  product_ids             String[]
  active                  Boolean         @default(true)
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt
  views_count             Int?            @default(0)
  sales_count             Int?            @default(0)
  custom_domain           String?
  affiliate_active        Boolean?
  affiliate_margin        Float?
  affiliate_media_kit_url String?
  analytics               PageAnalytics[]
  store                   Store           @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, slug])
  @@schema("public")
}

model Order {
  id                       String          @id @default(uuid())
  buyer_id                 String?
  buyer_name               String
  buyer_phone              String
  store_id                 String
  product_id               String
  variant_id               String?
  quantity                 Int             @default(1)
  subtotal                 Float
  promo_discount           Float           @default(0)
  platform_fee             Float
  vendor_amount            Float
  total                    Float
  status                   OrderStatus     @default(confirmed)
  payment_method           String
  payment_ref              String?
  affiliate_token          String?
  delivery_address         String?
  created_at               DateTime        @default(now())
  updated_at               DateTime        @updatedAt
  applied_promo_id         String?
  cod_cash_collected       Boolean         @default(false)
  cod_confirmed_at         DateTime?
  cod_fraud_suspected      Boolean         @default(false)
  commission_frozen_amount Int             @default(0)
  download_expires_at      DateTime?
  download_token           String?
  order_type               String          @default("physical")
  slot_reserved_until      DateTime?
  tracking_number          String?
  last_reminder_at         DateTime?       @db.Timestamptz(6)
  is_archived              Boolean?        @default(false)
  delivery_zone_id         String?
  delivery_fee             Float           @default(0)
  delivery_commission      Float           @default(0)
  buyer_email              String?
  affiliate_amount         Float?          @default(0)
  affiliate_subid          String?
  is_subscription          Boolean         @default(false)
  next_billing_at          DateTime?
  deliverer_id             String?
  bump_product_id          String?
  bump_variant_id          String?
  booking                  Booking?
  closing                  ClosingRequest?
  digitalAccess            DigitalAccess[]
  invoices                 Invoice[]
  promo_code               PromoCode?      @relation(fields: [applied_promo_id], references: [id])
  buyer                    User?           @relation(fields: [buyer_id], references: [id])
  deliverer                Deliverer?      @relation(fields: [deliverer_id], references: [id])
  deliveryZone             DeliveryZone?   @relation(fields: [delivery_zone_id], references: [id])
  product                  Product         @relation(fields: [product_id], references: [id])
  store                    Store           @relation(fields: [store_id], references: [id])
  variant                  ProductVariant? @relation(fields: [variant_id], references: [id])
  reports                  Report[]
  Review                   Review[]
  telegramMember           TelegramMember?

  @@index([store_id])
  @@index([buyer_id])
  @@index([created_at])
  @@index([deliverer_id])
  @@index([buyer_id], map: "idx_order_buyer_id")
  @@index([is_archived], map: "idx_order_is_archived")
  @@index([product_id], map: "idx_order_product_id")
  @@index([applied_promo_id], map: "idx_order_promo_id")
  @@index([status, updated_at], map: "idx_order_status_updated")
  @@index([store_id], map: "idx_order_store_id")
  @@schema("public")
}

model Notification {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String
  type       String   @default("order")
  title      String
  message    String
  link       String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at(sort: Desc)])
  @@index([user_id])
  @@schema("public")
}

model NpsResponse {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String
  score      Int
  comment    String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@schema("public")
}

model Wallet {
  id                      String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  vendor_id               String              @unique
  balance                 Float               @default(0)
  pending                 Float               @default(0)
  total_earned            Float               @default(0)
  updated_at              DateTime            @updatedAt
  auto_withdraw_enabled   Boolean?            @default(false)
  auto_withdraw_threshold Float?              @default(100000)
  monthly_goal            Float?              @default(1000000)
  vendor                  Store               @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  withdrawals             Withdrawal[]
  WithdrawalRequest       WithdrawalRequest[]
  transactions            Transaction[]

  @@schema("public")
}

model Transaction {
  id         String   @id @default(uuid())
  wallet_id  String
  type       String   @default("deposit")
  amount     Float
  status     String   @default("pending")
  label      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  wallet     Wallet   @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id])
  @@index([status])
  @@schema("public")
}

model Withdrawal {
  id             String           @id @default(uuid())
  wallet_id      String
  amount         Float
  status         WithdrawalStatus @default(pending)
  payment_method String
  requested_at   DateTime         @default(now())
  processed_at   DateTime?
  notes          String?
  phone_or_iban  String?
  store_id       String?
  wallet         Wallet           @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id], map: "idx_withdrawal_wallet_id")
  @@schema("public")
}

model Affiliate {
  id                   String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  store_id             String
  code                 String                 @unique
  balance              Decimal?               @default(0) @db.Decimal(12, 2)
  total_earned         Float?                 @default(0)
  total_referred       Int?                   @default(0)
  active_referred      Int?                   @default(0)
  commission_rate      Float?                 @default(5.00)
  is_active            Boolean?               @default(true)
  contract_accepted    Boolean?               @default(false)
  contract_accepted_at DateTime?              @db.Timestamptz(6)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  token                String?
  clicks               Int                    @default(0)
  conversions          Int                    @default(0)
  status               String                 @default("pending")
  user_id              String                 @default("")
  vendor_id            String                 @default("")
  total_withdrawn      Float                  @default(0)
  telegram_chat_id     String?
  Store                Store                  @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  AffiliateClickLog    AffiliateClickLog[]
  AffiliateReferral    AffiliateReferral[]
  AffiliateTransaction AffiliateTransaction[]
  AffiliateWithdrawal  AffiliateWithdrawal[]
  PromoCode            PromoCode[]

  @@index([code], map: "idx_affiliate_code")
  @@index([store_id], map: "idx_affiliate_store_id")
  @@schema("public")
}

model PromoCode {
  id           String     @id @default(uuid())
  store_id     String
  code         String
  type         String
  value        Float
  min_order    Float?
  max_uses     Int?
  uses         Int        @default(0)
  expires_at   DateTime?
  active       Boolean    @default(true)
  product_ids  String[]
  created_at   DateTime   @default(now())
  orders       Order[]
  store        Store      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  affiliate_id String?
  Affiliate    Affiliate? @relation(fields: [affiliate_id], references: [id], onDelete: SetNull)

  @@unique([store_id, code])
  @@schema("public")
}

model PageAnalytics {
  id            String   @id @default(uuid())
  page_id       String
  visits        Int      @default(0)
  clicks        Int      @default(0)
  purchases     Int      @default(0)
  cancellations Int      @default(0)
  date          DateTime @default(now())
  page          SalePage @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@unique([page_id, date])
  @@schema("public")
}

model PlatformConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  commission_rate Float    @default(0.10)
  updated_at      DateTime @default(now()) @updatedAt
  updated_by      String?
  key             String?  @unique
  value           String?

  @@schema("public")
}

model IntegrationKey {
  key        String   @id
  value      String
  updated_at DateTime @default(now()) @updatedAt
  updated_by String?

  @@schema("public")
}

model DigitalAccess {
  id             String        @id @default(uuid())
  order_id       String
  product_id     String
  token          String        @unique
  downloads_used Int           @default(0)
  downloads_max  Int?
  expires_at     DateTime?
  revoked        Boolean       @default(false)
  created_at     DateTime      @default(now())
  order          Order         @relation(fields: [order_id], references: [id])
  product        Product       @relation(fields: [product_id], references: [id])
  downloadLogs   DownloadLog[]

  @@schema("public")
}

model DownloadLog {
  id                String        @id @default(uuid())
  digital_access_id String
  ip_address        String?
  user_agent        String?
  downloaded_at     DateTime      @default(now())
  digitalAccess     DigitalAccess @relation(fields: [digital_access_id], references: [id])

  @@schema("public")
}

model Invoice {
  id          String   @id @default(uuid())
  order_id    String
  numero      String   @unique
  pdf_url     String?
  white_label Boolean  @default(false)
  created_at  DateTime @default(now())
  order       Order    @relation(fields: [order_id], references: [id])

  @@schema("public")
}

model ShortLink {
  id         String           @id @default(uuid())
  code       String           @unique
  target_url String
  store_id   String?
  product_id String?
  clicks     Int              @default(0)
  created_at DateTime         @default(now())
  analytics  ClickAnalytics[]
  product    Product?         @relation(fields: [product_id], references: [id])
  store      Store?           @relation(fields: [store_id], references: [id])

  @@index([store_id], map: "idx_shortlink_store_id")
  @@schema("public")
}

model ClickAnalytics {
  id            String    @id @default(uuid())
  short_link_id String
  source        String?
  city          String?
  country       String?
  converted     Boolean   @default(false)
  created_at    DateTime  @default(now())
  shortLink     ShortLink @relation(fields: [short_link_id], references: [id])

  @@schema("public")
}

model Promotion {
  id                String    @id @default(uuid())
  store_id          String
  type              String
  title             String
  discount_type     String
  discount_value    Int?
  min_order_amount  Int?
  product_ids       String[]
  bundle_config     Json?
  starts_at         DateTime
  ends_at           DateTime?
  active            Boolean   @default(true)
  views             Int       @default(0)
  conversions       Int       @default(0)
  revenue_generated Int       @default(0)
  created_at        DateTime  @default(now())
  store             Store     @relation(fields: [store_id], references: [id])

  @@schema("public")
}

model AdminLog {
  id          String   @id @default(uuid())
  admin_id    String
  action      String
  target_type String?
  target_id   String?
  details     Json?
  created_at  DateTime @default(now())
  admin       User     @relation(fields: [admin_id], references: [id])

  @@index([admin_id], map: "idx_admin_log_admin")
  @@index([created_at], map: "idx_admin_log_created_at")
  @@index([target_type, target_id], map: "idx_admin_log_target")
  @@schema("public")
}

model Report {
  id          String   @id @default(uuid())
  order_id    String
  reporter_id String
  type        String
  description String
  status      String   @default("open")
  admin_notes String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  order       Order    @relation(fields: [order_id], references: [id])
  reporter    User     @relation(fields: [reporter_id], references: [id])

  @@schema("public")
}

model StoreScore {
  id         String   @id @default(uuid())
  store_id   String   @unique
  score      Int      @default(0)
  featured   Boolean  @default(false)
  updated_at DateTime @default(now())
  store      Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model Subscription {
  id          String    @id @default(uuid())
  vendor_id   String
  plan        String    @default("free")
  expires_at  DateTime?
  payment_ref String?
  created_at  DateTime  @default(now())
  vendor      Store     @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@index([vendor_id], map: "idx_subscription_vendor_id")
  @@schema("public")
}

model Tip {
  id          String    @id @default(uuid())
  type        String
  title       String
  content     String
  cta_label   String?
  cta_url     String?
  target_plan String?
  pinned      Boolean   @default(false)
