// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  super_admin
  gestionnaire
  vendeur
  affilie
  acheteur
}

enum ProductType {
  digital
  physical
  coaching
}

enum OrderStatus {
  confirmed
  preparing
  shipped
  delivered
  cancelled
}

enum WithdrawalStatus {
  pending
  approved
  rejected
  paid
}

model User {
  id           String   @id @default(uuid())
  role         Role     @default(acheteur)
  name         String
  phone        String   @unique
  email        String?
  address      String?
  location_lat Float?
  location_lng Float?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  store       Store?
  orders      Order[]
  affiliates  Affiliate[]
}

model Store {
  id            String  @id @default(uuid())
  user_id       String  @unique
  name          String
  slug          String  @unique
  logo_url      String?
  primary_color String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user     User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products Product[]
  pages    SalePage[]
  orders   Order[]
  wallet   Wallet?
  promos   Promo[]
}

model Product {
  id          String      @id @default(uuid())
  store_id    String
  type        ProductType
  name        String
  description String?
  price       Float
  images      String[]
  category    String?
  active      Boolean     @default(true)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  store    Store            @relation(fields: [store_id], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  orders   Order[]
}

model ProductVariant {
  id           String  @id @default(uuid())
  product_id   String
  dimension_1  String?
  value_1      String?
  dimension_2  String?
  value_2      String?
  stock        Int     @default(0)
  price_adjust Float   @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  orders  Order[]
}

model SalePage {
  id          String   @id @default(uuid())
  store_id    String
  title       String
  slug        String
  template    String
  sections    Json
  product_ids String[]
  active      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  store     Store          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  analytics PageAnalytics[]

  @@unique([store_id, slug])
}

model Order {
  id               String      @id @default(uuid())
  buyer_id         String?
  buyer_name       String
  buyer_phone      String
  store_id         String
  product_id       String
  variant_id       String?
  quantity         Int         @default(1)
  subtotal         Float
  promo_discount   Float       @default(0)
  platform_fee     Float       // 10% PDV Pro — toujours calculé en premier
  vendor_amount    Float       // subtotal - promo_discount - platform_fee
  total            Float
  status           OrderStatus @default(confirmed)
  payment_method   String
  payment_ref      String?
  affiliate_token  String?
  delivery_address String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  buyer   User?          @relation(fields: [buyer_id], references: [id])
  store   Store          @relation(fields: [store_id], references: [id])
  product Product        @relation(fields: [product_id], references: [id])
  variant ProductVariant? @relation(fields: [variant_id], references: [id])
}

model Wallet {
  id           String @id @default(uuid())
  vendor_id    String @unique
  balance      Float  @default(0)
  pending      Float  @default(0)
  total_earned Float  @default(0)
  updated_at   DateTime @updatedAt

  vendor      Store        @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]
}

model Withdrawal {
  id             String           @id @default(uuid())
  wallet_id      String
  amount         Float
  status         WithdrawalStatus @default(pending)
  payment_method String
  requested_at   DateTime         @default(now())
  processed_at   DateTime?
  notes          String?

  wallet Wallet @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
}

model Affiliate {
  id              String @id @default(uuid())
  vendor_id       String
  user_id         String
  token           String @unique
  commission_rate Float
  clicks          Int    @default(0)
  conversions     Int    @default(0)
  total_earned    Float  @default(0)
  created_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Promo {
  id         String    @id @default(uuid())
  store_id   String
  code       String
  type       String    // percent | fixed
  value      Float
  max_uses   Int?
  uses       Int       @default(0)
  expires_at DateTime?
  active     Boolean   @default(true)
  created_at DateTime  @default(now())

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, code])
}

model PageAnalytics {
  id            String   @id @default(uuid())
  page_id       String
  visits        Int      @default(0)
  clicks        Int      @default(0)
  purchases     Int      @default(0)
  cancellations Int      @default(0)
  date          DateTime @default(now())

  page SalePage @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@unique([page_id, date])
}

model PlatformConfig {
  id              String   @id @default(uuid())
  commission_rate Float    @default(0.10) // 10% par défaut
  updated_at      DateTime @updatedAt
  updated_by      String?
}
