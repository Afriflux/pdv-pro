enum LeadStatus {
  new
  contacted
  qualified
  won
  lost

  @@schema("public")
}

model Lead {
  id         String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  store_id   String
  product_id String?
  closer_id  String? // ID of the closer who claimed it
  status     LeadStatus @default(new)

  // Prospect Info
  name  String
  phone String
  email String?

  // Context
  source String  @default("abandoned_cart") // or "callback_request"
  notes  String?

  claimed_at DateTime? @db.Timestamptz(6)
  closed_at  DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  commission_amount Float?

  Store   Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  Product Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([store_id], map: "idx_lead_store")
  @@index([closer_id], map: "idx_lead_closer")
  @@index([status], map: "idx_lead_status")
  @@schema("public")
}

model BioLink {
  id          String   @id @default(uuid())
  user_id     String   @unique
  slug        String   @unique
  title       String?  
  bio         String?
  avatar_url  String?
  banner_url  String?
  brand_color String   @default("#0F7A60")
  theme             String   @default("light")
  links             Json?    @default("[]")
  socials           Json?    @default("[]")
  newsletter_active Boolean? @default(false)
  newsletter_text   String?  @default("Abonnez-vous à ma newsletter")
  tip_active        Boolean? @default(false)
  tip_text          String?  @default("Offrez-moi un café ☕️")
  phone_active      Boolean? @default(false)
  phone_number      String?
  phone_text        String?  @default("Appeler Maintenant 📞")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  views             Int      @default(0)
  clicks            Int      @default(0)

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@schema("public")
}

model ThemeTemplate {
  id              String   @id @default(uuid())
  store_id        String?  // Null if global, otherwise belongs to a store
  name            String
  description     String?
  type            String   // "sale_page", "product_page", "bio_link", etc.
  category        String   
  sub_category    String? 
  niche           String?
  preview_url     String?
  data            Json
  is_premium      Boolean  @default(false)
  price           Float    @default(0)
  is_global       Boolean  @default(false)
  allowed_roles   String[] @default(["all"])
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  store           Store?   @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@schema("public")
}

model InstalledApp {
  id           String   @id @default(uuid())
  store_id     String
  app_id       String
  installed_at DateTime @default(now())
  status       String   @default("active")
  settings     Json?

  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, app_id])
  @@index([store_id])
  @@schema("public")
}

model AssetPurchase {
  id            String   @id @default(uuid())
  store_id      String
  asset_type    String   // "template", "masterclass", "workflow"
  asset_id      String
  amount_paid   Float
  purchased_at  DateTime @default(now())
  store         Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@schema("public")
}

model PaymentLink {
  id          String   @id @default(uuid())
  store_id    String
  title       String
  description String?
  amount      Float
  currency    String   @default("XOF")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  store       Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@schema("public")
}

model Quote {
  id           String   @id @default(uuid())
  store_id     String
  client_name  String
  client_email String?
  client_phone String?
  items        Json
  total_amount Float
  status       String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  expires_at   DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@schema("public")
}

model HelpdeskTicket {
  id             String    @id @default(uuid())
  store_id       String
  order_id       String?
  customer_name  String
  customer_email String?
  customer_phone String?
  subject        String
  message        String
  status         String    @default("OPEN")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)
  
  @@index([store_id])
  @@schema("public")
}

model DailyDigest {
  id          String   @id @default(uuid())
  store_id    String
  date        DateTime @db.Date
  summary     String
  metrics     Json     // {visitors, orders, revenue, avg_cart, abandoned, top_product}
  suggestions Json     // [{text, priority, action_url}]
  score       Int      @default(0)
  read        Boolean  @default(false)
  created_at  DateTime @default(now())

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, date])
  @@index([store_id])
  @@schema("public")
}

model WhatsappBot {
  id                String   @id @default(uuid())
  store_id          String   @unique
  active            Boolean  @default(false)
  welcome_message   String   @default("Bienvenue ! Tapez *catalogue* pour voir nos produits ou *aide* pour les commandes disponibles.")
  auto_reply        Boolean  @default(true)
  ai_enabled        Boolean  @default(false)
  phone_number      String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  store             Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model WhatsappConversation {
  id           String   @id @default(uuid())
  store_id     String
  phone        String
  client_name  String?
  last_message String?
  context      Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([store_id, phone])
  @@schema("public")
}

model SmsCredit {
  id          String   @id @default(uuid())
  store_id    String
  store       Store    @relation(fields: [store_id], references: [id])
  credits     Int      @default(0)
  used        Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([store_id])
  @@schema("public")
}

model SmsCampaign {
  id            String   @id @default(uuid())
  store_id      String
  store         Store    @relation(fields: [store_id], references: [id])
  name          String
  message       String   // max 160 chars
  recipients    Json     // [{phone: "+221...", name: "..."}]
  total_sent    Int      @default(0)
  total_failed  Int      @default(0)
  status        String   @default("draft") // draft | sending | completed | failed
  scheduled_at  DateTime?
  sent_at       DateTime?
  created_at    DateTime @default(now())

  @@schema("public")
}

model SmsLog {
  id           String   @id @default(uuid())
  store_id     String
  phone        String
  message      String
  type         String   // campaign | auto_abandoned | auto_confirm | auto_tracking
  status       String   @default("sent") // sent | delivered | failed
  twilio_sid   String?
  campaign_id  String?
  created_at   DateTime @default(now())

  @@schema("public")
}

model LoyaltyAccount {
  id              String   @id @default(uuid())
  phone           String   @unique // Le numéro de l'acheteur (identifiant universel global)
  total_earned    Int      @default(0) // Total points gagnés (pour le niveau)
  balance         Int      @default(0) // Points disponibles à dépenser
  tier            String   @default("bronze") // bronze | silver | gold | diamond
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  transactions    LoyaltyTransaction[]

  @@schema("public")
}

model LoyaltyTransaction {
  id              String   @id @default(uuid())
  account_id      String
  account         LoyaltyAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  type            String   // earn | redeem | bonus | expire
  points          Int      // Positif pour earn/bonus, négatif pour redeem
  description     String
  order_id        String?  // Lié à quelle commande
  store_id        String?  // Chez quel vendeur
  store           Store?   @relation(fields: [store_id], references: [id], onDelete: SetNull)
  created_at      DateTime @default(now())

  @@schema("public")
}

model LoyaltyConfig {
  id              String   @id @default(uuid())
  store_id        String   @unique
  store           Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(false)
  points_per_100  Int      @default(1)   // 1 point par 100 FCFA dépensé
  max_redeem_pct  Int      @default(20)  // Max 20% de la commande payable en points
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// ── SYSTEME D'EXPLOITATION YAYYAM OS (ERP / BOARD / COMPTABILITÉ) ───────────
// ─────────────────────────────────────────────────────────────────────────────

// 1. RBAC (Access Control) DYNAMIQUE
model InternalRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  color_cls   String?  @default("text-emerald-600 border-emerald-300")
  bg_cls      String?  @default("bg-emerald-50")
  is_custom   Boolean  @default(true)
  
  permissions Json     @default("{}") // ex: { "dashboard": "full", "vendors": "read" }
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  users       User[]
  @@schema("public")
}

// 2. CENTRE D'AUDIT (Security Logs)
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  action     String   // ex: "MODIFIED_ROLE", "DELETED_VENDOR"
  module     String   // ex: "RBAC", "VENDORS", "FINANCES"
  details    Json?    // Detailed footprint of what changed
  ip_address String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id], map: "idx_audit_user")
  @@index([action], map: "idx_audit_action")
  @@schema("public")
}

// 3. RH / STAFF (Hierarchy & Payroll)
model EmployeeContract {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @unique
  job_title       String
  department      String   // ex: "Support", "Direction", "IT"
  base_salary     Float    @default(0) // Salaire de base
  status          String   @default("active") // active, suspended, terminated
  hired_at        DateTime @default(now()) @db.Timestamptz(6)
  terminated_at   DateTime? @db.Timestamptz(6)

  User            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@schema("public")
}

// 4. ACTIONNARIAT / BOARD (Smart Contracts for Equity)
model ShareholderEquity {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String
  equity_percent  Float    // ex: 20 for 20%
  start_date      DateTime @default(now()) @db.Timestamptz(6)
  end_date        DateTime? @db.Timestamptz(6) // Null = Durée indéterminée
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  
  User            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Distributions   DividendDistribution[]
  @@schema("public")
}

model DividendDistribution {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equity_id        String   @db.Uuid
  amount_distrib   Float
  net_profit_ref   Float    // Base de bénéfice utilisée pour calculer
  distributed_at   DateTime @default(now()) @db.Timestamptz(6)

  Equity           ShareholderEquity @relation(fields: [equity_id], references: [id])
  @@schema("public")
}

// 5. COMPTABILITÉ INTERNE (P&L - Expenses)
model CompanyExpense {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   // ex: "Vercel Hosting", "Meta Ads"
  category    String   // ex: "SERVERS", "MARKETING", "PAYROLL"
  amount      Float
  is_recurring Boolean @default(false)
  frequency   String?  // ex: "monthly"
  expense_date DateTime @default(now()) @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  
  @@schema("public")
}
