'use client'

import { useState, useTransition } from 'react'
import { toggleVolumeDiscountsAction, saveVolumeConfigAction } from './actions'
import { toast } from '@/lib/toast'
import { Settings2, Save, Plus, Trash2, Tag } from 'lucide-react'

export type DiscountRule = {
  id: string
  quantity: number
  discountType: 'percentage' | 'fixed'
  value: number
}

export function VolumeDiscountsControls({ 
  initialActive, 
  initialConfig 
}: { 
  initialActive: boolean
  initialConfig: any 
}) {
  const [isActive, setIsActive] = useState(initialActive)
  const [isPending, startTransition] = useTransition()
  
  const parsedConfig = typeof initialConfig === 'string' ? JSON.parse(initialConfig) : (initialConfig || {})
  
  const [config, setConfig] = useState({
    title: parsedConfig.title || "Achetez plus, économisez plus !",
    rules: (parsedConfig.rules || []) as DiscountRule[]
  })

  // S'il n'y a pas de règle par défaut, on en ajoute une pour l'exemple
  if (config.rules.length === 0) {
    config.rules.push({ id: 'default-1', quantity: 2, discountType: 'percentage', value: 10 })
  }

  const [savingConfig, setSavingConfig] = useState(false)

  const handleToggle = () => {
    const newActiveState = !isActive
    setIsActive(newActiveState)
    startTransition(async () => {
      const res = await toggleVolumeDiscountsAction(newActiveState)
      if (res.success) {
        toast.success(newActiveState ? "Prix de Gros activés !" : "Application désactivée.")
      } else {
        toast.error("Une erreur s'est produite.")
        setIsActive(!newActiveState)
      }
    })
  }

  const handleSaveConfig = async () => {
    setSavingConfig(true)
    const res = await saveVolumeConfigAction(config)
    setSavingConfig(false)
    if (res.success) {
      toast.success("Règles B2B sauvegardées avec succès !")
    } else {
      toast.error("Impossible de sauvegarder la configuration.")
    }
  }

  const addRule = () => {
    setConfig(prev => ({
      ...prev,
      rules: [...prev.rules, { id: Math.random().toString(36).substr(2, 9), quantity: 3, discountType: 'percentage', value: 15 }]
    }))
  }

  const removeRule = (id: string) => {
    setConfig(prev => ({
      ...prev,
      rules: prev.rules.filter(r => r.id !== id)
    }))
  }

  const updateRule = (id: string, updates: Partial<DiscountRule>) => {
    setConfig(prev => ({
      ...prev,
      rules: prev.rules.map(r => r.id === id ? { ...r, ...updates } : r).sort((a, b) => a.quantity - b.quantity)
    }))
  }

  return (
    <div className="space-y-6">
      {/* ── Main Switch ── */}
      <div className="flex md:items-center flex-col md:flex-row justify-between bg-white p-5 rounded-2xl border border-gray-100 shadow-sm gap-4">
        <div className="flex flex-col">
          <span className="font-bold text-[#1A1A1A] text-base">{isActive ? "Moteur de réductions : Actif" : "Moteur de réductions : Inactif"}</span>
          <span className={`text-xs font-medium ${isActive ? "text-emerald-600" : "text-gray-400"}`}>
            {isActive ? "Vos clients verront les prix dégressifs et vos paniers seront mis à jour." : "Aucune réduction automatique n'est appliquée en vitrine."}
          </span>
        </div>
        
        <button
          onClick={handleToggle}
          disabled={isPending}
          className={`${
            isActive ? 'bg-[#0F7A60]' : 'bg-gray-200'
          } relative inline-flex h-8 w-14 shrink-0 appearance-none items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-[#0F7A60] focus:ring-offset-2 disabled:opacity-50`}
          role="switch"
          aria-checked={isActive}
        >
          <span className="sr-only">Activer Volume Discounts</span>
          <span
            className={`${
              isActive ? 'translate-x-7' : 'translate-x-1'
            } inline-block h-6 w-6 transform rounded-full bg-white transition-transform shadow-sm`}
          />
        </button>
      </div>

      {/* ── Advanced Configuration (Rules Builder) ── */}
      {isActive && (
        <div className="mt-8 pt-8 border-t border-gray-100 animate-in fade-in slide-in-from-top-4 duration-500">
          <div className="flex items-center gap-2 mb-6">
            <Settings2 size={18} className="text-gray-400" />
            <h3 className="text-sm font-black text-gray-900 uppercase tracking-widest">Générateur de Paliers</h3>
          </div>
          
          {/* Custom Message */}
          <div className="bg-gray-50/50 p-5 rounded-[20px] border border-gray-100 mb-6">
            <label className="block text-xs font-bold text-gray-500 mb-2">Message Incitatif sur la Vitrine</label>
            <input 
              type="text" 
              value={config.title}
              onChange={e => setConfig({...config, title: e.target.value})}
              className="w-full bg-white border border-gray-200 text-sm font-bold text-gray-800 rounded-xl px-4 py-2.5 focus:outline-none focus:border-[#0F7A60] focus:ring-1 focus:ring-[#0F7A60]"
              placeholder="Ex: Achetez en gros et économisez !"
            />
          </div>

          <div className="grid gap-4 mb-6">
            {config.rules.map((rule, idx) => (
              <div key={rule.id} className="flex flex-col sm:flex-row gap-3 bg-white border border-gray-200 p-4 rounded-xl shadow-sm items-start sm:items-center">
                <div className="flex w-full items-center gap-3">
                  <div className="flex-shrink-0 w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center font-bold text-gray-500 text-xs shadow-inner">
                    {idx + 1}
                  </div>
                  <div className="flex flex-1 gap-2 items-center">
                    <span className="text-xs font-bold text-gray-500 shrink-0">Pour</span>
                    <input 
                      type="number" min="2" max="100"
                      value={rule.quantity}
                      onChange={e => updateRule(rule.id, { quantity: parseInt(e.target.value) || 2 })}
                      className="w-16 bg-gray-50 border border-gray-200 text-sm font-bold rounded-lg px-2 py-1.5 focus:outline-none"
                    />
                    <span className="text-xs font-bold text-gray-500 shrink-0">articles :</span>
                  </div>
                </div>

                <div className="flex w-full sm:w-auto items-center gap-2">
                  <span className="text-xs font-bold text-rose-500 bg-rose-50 px-2 py-1 rounded-md border border-rose-100">-</span>
                  <input 
                    type="number" min="1"
                    value={rule.value}
                    onChange={e => updateRule(rule.id, { value: parseInt(e.target.value) || 0 })}
                    className="w-20 bg-rose-50 border border-rose-100 text-rose-600 text-sm font-black rounded-lg px-2 py-1.5 focus:outline-none"
                  />
                  <select
                    value={rule.discountType}
                    onChange={e => updateRule(rule.id, { discountType: e.target.value as 'percentage' | 'fixed' })}
                    className="bg-transparent text-xs font-bold text-gray-700 cursor-pointer focus:outline-none"
                  >
                    <option value="percentage">% de réduc.</option>
                    <option value="fixed">FCFA / Net</option>
                  </select>

                  <button onClick={() => removeRule(rule.id)} className="ml-auto sm:ml-2 p-2 text-gray-300 hover:text-red-500 transition-colors">
                    <Trash2 size={16} />
                  </button>
                </div>
              </div>
            ))}
          </div>

          <button 
            onClick={addRule}
            className="w-full flex items-center justify-center gap-2 py-3 bg-gray-50 border border-dashed border-gray-300 text-gray-600 hover:text-gray-900 rounded-xl font-bold text-sm mb-6 hover:bg-gray-100/50 transition-colors"
          >
            <Plus size={16} /> Ajouter un palier B2B
          </button>

          <button 
            onClick={handleSaveConfig}
            disabled={savingConfig}
            className="w-full flex items-center justify-center gap-2 py-4 bg-[#1A1A1A] text-white rounded-xl font-bold text-sm hover:scale-[1.01] transition-transform disabled:opacity-50 shadow-xl shadow-black/10"
          >
            {savingConfig ? "Sauvegarde en cours..." : <><Save size={18} /> Sauvegarder l'algorithme B2B</>}
          </button>
        </div>
      )}
    </div>
  )
}
